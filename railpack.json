{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11"
  },
  "deploy": {
    "startCommand": "uvicorn backend.app:app --host 0.0.0.0 --port ${PORT:-8000}",
    "aptPackages": ["ffmpeg"],
    "variables": {
      "FRONTEND_URL": "https://shrewscape.vercel.app",
      "CORS_ORIGIN_REGEX": "https://([a-z0-9-]+\\.)*vercel\\.app"
    }
  }
}
